<UserControl
    x:Class="RedfishViewer.Views.About"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="576"
    d:DesignWidth="1024"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    FontFamily="{materialDesign:MaterialDesignFont}"
    TextElement.FontSize="14"
    TextElement.FontWeight="Medium"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Width="320"
            Margin="0,48"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <!--  ロゴ  -->
            <Image
                Width="120"
                Height="120"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                Source="pack://application:,,,/RedfishViewer.png" />
            <!--  アプリ名  -->
            <TextBlock
                HorizontalAlignment="Center"
                Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                Text="RedfishViewer" />
            <!--  バージョン  -->
            <TextBlock
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                Opacity="0.6"
                Style="{StaticResource MaterialDesignBody2TextBlock}"
                Text="{Binding AppVersion}" />
            <Separator Margin="0,24" />
            <!--  コピーライト  -->
            <TextBlock
                Margin="0,0,0,24"
                HorizontalAlignment="Center"
                Opacity="0.7"
                Style="{StaticResource MaterialDesignBody1TextBlock}"
                Text="{Binding AppCopyright}" />
            <!--  GitHub  -->
            <Button
                Margin="0,6"
                Command="{Binding OpenGitHubCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Kind="Github" />
                    <TextBlock VerticalAlignment="Center" Text="GitHub - RedfishViewer" />
                </StackPanel>
            </Button>
            <!--  ブログ  -->
            <Button
                Margin="0,6"
                Command="{Binding OpenBlogCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Kind="Earth" />
                    <TextBlock VerticalAlignment="Center" Text="Tabito's Voyage" />
                </StackPanel>
            </Button>
            <!--  X (Twitter)  -->
            <Button
                Margin="0,6"
                Command="{Binding OpenXCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Kind="Twitter" />
                    <TextBlock VerticalAlignment="Center" Text="@TabitosPharos" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
